{
  "manifest_version": 3,
  "name": "FEU Canvas Helper",
  "version": "1.1.0",
  "description": "Pending work dashboard, module blocker finder, and headless auto-next navigator for FEU Canvas.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "https://feu.instructure.com/*",
    "https://*.instructure.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://feu.instructure.com/*",
        "https://*.instructure.com/*"
      ],
      "js": ["autonext-runner.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "FEU Canvas Helper",
    "default_popup": "popup.html"
  }
}
