{
  "manifest_version": 3,
  "name": "FEU Canvas Helper",
  "version": "1.3.0",
  "description": "Pending work dashboard with headless API autonext, module blocker finder, and bulk auto-sweep for FEU Canvas.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "https://feu.instructure.com/*",
    "https://*.instructure.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://feu.instructure.com/*",
        "https://*.instructure.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "FEU Canvas Helper",
    "default_popup": "popup.html"
  }
}
